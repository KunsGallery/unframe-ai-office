rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function userEmail() {
      return isSignedIn() ? request.auth.token.email : "";
    }

    function isOwner() {
      return isSignedIn() &&
        userEmail() == "gallerykuns@gmail.com";
    }

    function isAllowedEmail(email) {
      return email == "gallerykuns@gmail.com" ||
        email == "sylove887@gmail.com";
      // Add additional staff emails here.
    }

    function isAllowedStaff() {
      return isSignedIn() && isAllowedEmail(userEmail());
    }

    function isAllowedRoom(roomId) {
      return roomId == "general" ||
        roomId == "exhibition" ||
        roomId == "up" ||
        roomId == "u-sharp" ||
        roomId == "join" ||
        roomId == "virtual-gallery";
    }

    function ownsExistingChat() {
      return resource.data.userEmail is string &&
        resource.data.userEmail == userEmail();
    }

    function ownsIncomingChat() {
      return request.resource.data.userEmail is string &&
        request.resource.data.userEmail == userEmail();
    }

    function isValidChatData(roomId) {
      return isAllowedRoom(roomId) &&
        request.resource.data.keys().hasAll([
          "agentId",
          "userEmail",
          "roomId",
          "createdAt",
          "updatedAt",
        ]) &&
        request.resource.data.keys().hasOnly([
          "agentId",
          "userEmail",
          "roomId",
          "summary",
          "createdAt",
          "updatedAt",
        ]) &&
        request.resource.data.agentId is string &&
        request.resource.data.agentId.size() > 0 &&
        request.resource.data.userEmail is string &&
        isAllowedEmail(request.resource.data.userEmail) &&
        request.resource.data.roomId is string &&
        request.resource.data.roomId == roomId &&
        request.resource.data.get("summary", "") is string &&
        request.resource.data.get("summary", "").size() <= 4000 &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp;
    }

    function parentChat(roomId, chatId) {
      return get(/databases/$(database)/documents/unframeChatRooms/$(roomId)/chats/$(chatId));
    }

    function canAccessParentChat(roomId, chatId) {
      return isAllowedRoom(roomId) && (
        isOwner() ||
        (
          exists(/databases/$(database)/documents/unframeChatRooms/$(roomId)/chats/$(chatId)) &&
          parentChat(roomId, chatId).data.userEmail is string &&
          parentChat(roomId, chatId).data.userEmail == userEmail()
        )
      );
    }

    function isValidMessageCreate() {
      return request.resource.data.keys().hasAll([
          "role",
          "content",
          "createdAt",
        ]) &&
        request.resource.data.keys().hasOnly([
          "role",
          "content",
          "createdAt",
          "usage",
          "mode",
        ]) &&
        (
          request.resource.data.role == "user" ||
          request.resource.data.role == "assistant"
        ) &&
        request.resource.data.content is string &&
        request.resource.data.content.size() <= 12000 &&
        request.resource.data.createdAt is timestamp &&
        (
          !request.resource.data.keys().hasAny(["mode"]) ||
          request.resource.data.mode == null ||
          request.resource.data.mode == "economy" ||
          request.resource.data.mode == "premium"
        ) &&
        (
          !request.resource.data.keys().hasAny(["usage"]) ||
          request.resource.data.usage == null ||
          request.resource.data.usage is map
        );
    }

    function ownsExistingTask() {
      return resource.data.userEmail is string &&
        resource.data.userEmail == userEmail();
    }

    function ownsIncomingTask() {
      return request.resource.data.userEmail is string &&
        request.resource.data.userEmail == userEmail();
    }

    function ownsExistingOutput() {
      return resource.data.userEmail is string &&
        resource.data.userEmail == userEmail();
    }

    function ownsIncomingOutput() {
      return request.resource.data.userEmail is string &&
        request.resource.data.userEmail == userEmail();
    }

    function isValidPresenceData(roomId, userKey) {
      return userKey.matches('^[a-z0-9_]+$') &&
        isAllowedRoom(roomId) &&
        request.resource.data.keys().hasAll([
          "userEmail",
          "displayName",
          "roomId",
          "roomName",
          "status",
          "avatarLabel",
          "x",
          "y",
          "updatedAt",
        ]) &&
        request.resource.data.keys().hasOnly([
          "userEmail",
          "displayName",
          "roomId",
          "roomName",
          "status",
          "avatarLabel",
          "x",
          "y",
          "updatedAt",
        ]) &&
        request.resource.data.userEmail is string &&
        request.resource.data.userEmail == userEmail() &&
        isAllowedEmail(request.resource.data.userEmail) &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 120 &&
        request.resource.data.roomId is string &&
        request.resource.data.roomId == roomId &&
        request.resource.data.roomName is string &&
        request.resource.data.roomName.size() <= 120 &&
        (
          request.resource.data.status == "online" ||
          request.resource.data.status == "offline"
        ) &&
        request.resource.data.avatarLabel is string &&
        request.resource.data.avatarLabel.size() <= 40 &&
        request.resource.data.x is number &&
        request.resource.data.y is number &&
        request.resource.data.updatedAt is timestamp;
    }

    function isAllowedTaskAgent(agentId) {
      return agentId == "director" ||
        agentId == "copy" ||
        agentId == "design" ||
        agentId == "music" ||
        agentId == "admin" ||
        agentId == "archive";
    }

    function isAllowedTaskStatus(status) {
      return status == "planned" ||
        status == "running" ||
        status == "completed" ||
        status == "failed" ||
        status == "archived";
    }

    function isAllowedTaskPriority(priority) {
      return priority == "low" ||
        priority == "normal" ||
        priority == "high";
    }

    function isAllowedOutputType(type) {
      return type == "exhibition_text" ||
        type == "instagram_copy" ||
        type == "design_prompt" ||
        type == "suno_prompt" ||
        type == "email_draft" ||
        type == "checklist" ||
        type == "article_draft" ||
        type == "interview_questions" ||
        type == "general";
    }

    function isValidOptionalTaskTime(value) {
      return value == null ||
        value is timestamp ||
        (value is string && value.size() <= 40);
    }

    function isValidQueueMeta(roomId, userSafeKey) {
      return isAllowedRoom(roomId) &&
        userSafeKey.matches('^[a-z0-9_]+$') &&
        request.resource.data.keys().hasAll([
          "userEmail",
          "roomId",
          "updatedAt",
        ]) &&
        request.resource.data.keys().hasOnly([
          "ownerEmail",
          "userEmail",
          "roomId",
          "createdAt",
          "updatedAt",
        ]) &&
        request.resource.data.userEmail is string &&
        isAllowedEmail(request.resource.data.userEmail) &&
        request.resource.data.roomId == roomId &&
        (
          !request.resource.data.keys().hasAny(["ownerEmail"]) ||
          (
            request.resource.data.ownerEmail is string &&
            isAllowedEmail(request.resource.data.ownerEmail)
          )
        ) &&
        (
          !request.resource.data.keys().hasAny(["createdAt"]) ||
          request.resource.data.createdAt is timestamp
        ) &&
        request.resource.data.updatedAt is timestamp;
    }

    function isValidTaskData(roomId) {
      return isAllowedRoom(roomId) &&
        request.resource.data.keys().hasAll([
          "title",
          "description",
          "assignedAgentId",
          "status",
          "priority",
          "goal",
          "planId",
          "roomId",
          "userEmail",
          "createdAt",
          "updatedAt",
        ]) &&
        request.resource.data.keys().hasOnly([
          "title",
          "description",
          "assignedAgentId",
          "status",
          "priority",
          "goal",
          "planId",
          "roomId",
          "userEmail",
          "ownerEmail",
          "expectedOutput",
          "result",
          "errorMessage",
          "usage",
          "mode",
          "sortOrder",
          "createdAt",
          "updatedAt",
          "executedAt",
          "completedAt",
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() <= 1200 &&
        request.resource.data.goal is string &&
        request.resource.data.goal.size() <= 3000 &&
        request.resource.data.planId is string &&
        request.resource.data.planId.size() <= 120 &&
        request.resource.data.roomId == roomId &&
        request.resource.data.userEmail is string &&
        isAllowedEmail(request.resource.data.userEmail) &&
        (
          !request.resource.data.keys().hasAny(["ownerEmail"]) ||
          (
            request.resource.data.ownerEmail is string &&
            isAllowedEmail(request.resource.data.ownerEmail)
          )
        ) &&
        isAllowedTaskAgent(request.resource.data.assignedAgentId) &&
        isAllowedTaskStatus(request.resource.data.status) &&
        isAllowedTaskPriority(request.resource.data.priority) &&
        request.resource.data.get("expectedOutput", "") is string &&
        request.resource.data.get("expectedOutput", "").size() <= 600 &&
        request.resource.data.get("result", "") is string &&
        request.resource.data.get("result", "").size() <= 12000 &&
        request.resource.data.get("errorMessage", "") is string &&
        request.resource.data.get("errorMessage", "").size() <= 500 &&
        (
          !request.resource.data.keys().hasAny(["usage"]) ||
          request.resource.data.usage == null ||
          request.resource.data.usage is map
        ) &&
        (
          !request.resource.data.keys().hasAny(["mode"]) ||
          request.resource.data.mode == null ||
          request.resource.data.mode == "economy" ||
          request.resource.data.mode == "premium"
        ) &&
        (
          !request.resource.data.keys().hasAny(["sortOrder"]) ||
          request.resource.data.sortOrder is int
        ) &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        isValidOptionalTaskTime(request.resource.data.get("executedAt", null)) &&
        isValidOptionalTaskTime(request.resource.data.get("completedAt", null));
    }

    function isValidOutputData(roomId) {
      return isAllowedRoom(roomId) &&
        request.resource.data.keys().hasAll([
          "title",
          "type",
          "content",
          "sourceTaskId",
          "sourceTaskTitle",
          "assignedAgentId",
          "roomId",
          "userEmail",
          "createdAt",
          "updatedAt",
        ]) &&
        request.resource.data.keys().hasOnly([
          "title",
          "type",
          "content",
          "sourceTaskId",
          "sourceTaskTitle",
          "assignedAgentId",
          "roomId",
          "userEmail",
          "createdAt",
          "updatedAt",
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 160 &&
        request.resource.data.type is string &&
        isAllowedOutputType(request.resource.data.type) &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 20000 &&
        request.resource.data.sourceTaskId is string &&
        request.resource.data.sourceTaskId.size() > 0 &&
        request.resource.data.sourceTaskId.size() <= 120 &&
        request.resource.data.sourceTaskTitle is string &&
        request.resource.data.sourceTaskTitle.size() <= 160 &&
        request.resource.data.assignedAgentId is string &&
        isAllowedTaskAgent(request.resource.data.assignedAgentId) &&
        request.resource.data.roomId is string &&
        request.resource.data.roomId == roomId &&
        request.resource.data.userEmail is string &&
        isAllowedEmail(request.resource.data.userEmail) &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp;
    }

    match /unframeChatRooms/{roomId} {
      allow read, write: if false;

      match /chats/{chatId} {
        allow get: if isAllowedRoom(roomId) && isAllowedStaff() && (isOwner() || ownsExistingChat());
        allow list: if false;

        allow create: if isAllowedRoom(roomId) && isAllowedStaff() &&
          (isOwner() || ownsIncomingChat()) &&
          isValidChatData(roomId);

        allow update: if isAllowedRoom(roomId) && isAllowedStaff() &&
          (isOwner() || ownsExistingChat()) &&
          (isOwner() || ownsIncomingChat()) &&
          isValidChatData(roomId);

        allow delete: if isAllowedRoom(roomId) && isAllowedStaff() && (isOwner() || ownsExistingChat());

        match /messages/{messageId} {
          allow get: if isAllowedStaff() && canAccessParentChat(roomId, chatId);
          allow list: if isAllowedStaff() && canAccessParentChat(roomId, chatId);

          allow create: if isAllowedStaff() &&
            canAccessParentChat(roomId, chatId) &&
            isValidMessageCreate();

          allow update: if false;

          allow delete: if isAllowedStaff() && canAccessParentChat(roomId, chatId);
        }
      }
    }

    match /unframeTaskRooms/{roomId} {
      allow read, write: if false;

      match /queues/{userSafeKey} {
        allow get: if isAllowedRoom(roomId) && isAllowedStaff() && (isOwner() || ownsExistingTask());
        allow list: if false;

        allow create: if isAllowedRoom(roomId) && isAllowedStaff() &&
          (isOwner() || ownsIncomingTask()) &&
          isValidQueueMeta(roomId, userSafeKey);

        allow update: if isAllowedRoom(roomId) && isAllowedStaff() &&
          (isOwner() || ownsExistingTask()) &&
          (isOwner() || ownsIncomingTask()) &&
          isValidQueueMeta(roomId, userSafeKey);

        allow delete: if false;

        match /tasks/{taskId} {
          allow get: if isAllowedRoom(roomId) && isAllowedStaff() &&
            (isOwner() || ownsExistingTask());

          allow list: if isAllowedRoom(roomId) && isAllowedStaff() &&
            (
              isOwner() ||
              (
                exists(/databases/$(database)/documents/unframeTaskRooms/$(roomId)/queues/$(userSafeKey)) &&
                get(/databases/$(database)/documents/unframeTaskRooms/$(roomId)/queues/$(userSafeKey)).data.userEmail is string &&
                get(/databases/$(database)/documents/unframeTaskRooms/$(roomId)/queues/$(userSafeKey)).data.userEmail == userEmail()
              )
            );

          allow create: if isAllowedRoom(roomId) && isAllowedStaff() &&
            (isOwner() || ownsIncomingTask()) &&
            isValidTaskData(roomId);

          allow update: if isAllowedRoom(roomId) && isAllowedStaff() &&
            (isOwner() || ownsExistingTask()) &&
            (isOwner() || ownsIncomingTask()) &&
            isValidTaskData(roomId);

          allow delete: if false;
        }
      }
    }

    match /unframeOutputRooms/{roomId} {
      allow read, write: if false;

      match /outputs/{outputId} {
        allow get: if isAllowedRoom(roomId) && isAllowedStaff() &&
          (isOwner() || ownsExistingOutput());

        allow list: if isAllowedRoom(roomId) && isAllowedStaff();

        allow create: if isAllowedRoom(roomId) && isAllowedStaff() &&
          ownsIncomingOutput() &&
          isValidOutputData(roomId);

        allow update: if isAllowedRoom(roomId) && isAllowedStaff() &&
          (isOwner() || ownsExistingOutput()) &&
          (isOwner() || ownsIncomingOutput()) &&
          isValidOutputData(roomId);

        allow delete: if isAllowedRoom(roomId) && isAllowedStaff() &&
          (isOwner() || ownsExistingOutput());
      }
    }

    match /unframePresence/{userKey} {
      allow get, list: if isAllowedStaff();

      allow create: if isAllowedStaff() &&
        request.resource.data.userEmail is string &&
        request.resource.data.userEmail == userEmail() &&
        isValidPresenceData(request.resource.data.roomId, userKey);

      allow update: if isAllowedStaff() &&
        resource.data.userEmail is string &&
        resource.data.userEmail == userEmail() &&
        request.resource.data.userEmail is string &&
        request.resource.data.userEmail == userEmail() &&
        isValidPresenceData(request.resource.data.roomId, userKey);

      allow delete: if isAllowedStaff() &&
        (
          isOwner() ||
          (
            resource.data.userEmail is string &&
            resource.data.userEmail == userEmail()
          )
        );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
